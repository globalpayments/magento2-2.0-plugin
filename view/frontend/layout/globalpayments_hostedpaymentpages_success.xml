<?xml version="1.0"?>
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" layout="1column" xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <head>
        <title>Thank you for your purchase!</title>
    </head>
    <body>
        <referenceContainer name="content">
        <block class="Magento\Framework\View\Element\Template" name="globalpayments.refresh.cart" cacheable="false" template="GlobalPayments_PaymentGateway::cart/refresh_cart.phtml"/>

            <block class="Magento\Checkout\Block\Onepage\Success" name="checkout.success" template="Magento_Checkout::success.phtml" cacheable="false">
                <container name="order.success.additional.info" label="Order Success Additional Info">
                    <block class="GlobalPayments\PaymentGateway\Block\Customer\VisaInstallments" 
                           name="globalpayments.visa.installments" 
                           template="GlobalPayments_PaymentGateway::customer/visa_installments_info.phtml" 
                           cacheable="false"/>
                </container>
            </block>
        </referenceContainer>
    </body>
</page>
